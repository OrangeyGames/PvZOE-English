[1,0,0,[["cc.JsonAsset",["_name","json"],1]],[[0,0,1,3]],[[0,"dialog",[{"id":1,"text_id":"get_hg","describle":"恭喜获得一个黄瓜炸弹"},{"id":2,"text_id":"diamond_notenougy","describle":"你的钻石不够，无法购买"},{"id":3,"text_id":"video_cd","describle":"视频广告冷却中，请稍后再试"},{"id":4,"text_id":"get_sun","describle":"'恭喜获得%{num}个太阳'"},{"id":5,"text_id":"fight_start_confirm","describle":"你的上阵植物不足，确定要继续吗？"},{"id":6,"text_id":"kaipai_1","describle":"场上所有植物攻击翻倍"},{"id":7,"text_id":"kaipai_2","describle":"本关所获得阳光翻倍"},{"id":8,"text_id":"kaipai_3","describle":"本关所有植物冷却时间减半"},{"id":9,"text_id":"kaipai_4","describle":"随机1个未上场的植物"},{"id":10,"text_id":"kaipai_5","describle":"随机1个满级的未上场植物"},{"id":11,"text_id":"kaipai_6","describle":"本关免费使用2次战术黄瓜"},{"id":12,"text_id":"get_fail","describle":"获取失败"},{"id":13,"text_id":"guide_1","describle":"把豌豆射手拖动到场地上种植吧！"},{"id":14,"text_id":"guide_2","describle":"试着给豌豆射手来个能量豆？！"},{"id":15,"text_id":"guide_3","describle":"如果事态紧急，记得使用战术黄瓜！"},{"id":16,"text_id":"pvz_dialog_1","describle":"时间线警告，戴夫同学！我们回到了出发前的时刻！"},{"id":17,"text_id":"pvz_dialog_2","describle":"如果我的猜测是正确的，僵尸头头博士想要阻止你最开始吃玉米卷的行为！"},{"id":18,"text_id":"pvz_dialog_3","describle":"我们的旅程就会不复存在！"},{"id":19,"text_id":"pvz_dialog_4","describle":"不————！抱歉，我在忙着喊“不”。你刚刚有提到“玉米卷”么？"},{"id":20,"text_id":"pvz_dialog_5","describle":"我们必须小心，戴夫同学。"},{"id":21,"text_id":"pvz_dialog_6","describle":"玉米卷——！"},{"id":22,"text_id":"pvz_dialog_7","describle":"这就是海盗世界啊！快去看看有什么不同！"},{"id":23,"text_id":"pvz_dialog_8","describle":"我们的目标不是你的玉米卷么？"},{"id":24,"text_id":"pvz_dialog_9","describle":"那可是海盗啊！你不想看看他们的鹦鹉和假腿吗？"},{"id":25,"text_id":"pvz_dialog_10","describle":"这里就是埃及？我听说埃及法老有不计其数的宝物，说不定这里能找到不少好东西。"},{"id":26,"text_id":"pvz_dialog_11","describle":"好东西不知道，僵尸倒有不少，准备战斗吧。"},{"id":27,"text_id":"pvz_dialog_12","describle":"警报！戴夫同学。我的感应器显示，我们已经进入到过去的一亿五千三百九十五万年。"},{"id":28,"text_id":"pvz_dialog_13","describle":"哇塞！那时候我还没出生呢！"},{"id":29,"text_id":"pvz_dialog_14","describle":"正确。我们好像进入了一片侏罗纪沼泽。"},{"id":30,"text_id":"pvz_dialog_15","describle":"难怪我闻到了更多的氧气！"},{"id":31,"text_id":"pvz_dialog_16","describle":"啊，这里是功夫世界，我要看气功表演！"},{"id":32,"text_id":"pvz_dialog_17","describle":"数据显示，会武术的僵尸危险系数提升2倍"},{"id":33,"text_id":"pvz_dialog_18","describle":"还要小心那些兵器架，好像僵尸特别喜欢拿上面的东西！"}]]],0,0,[],[],[]]